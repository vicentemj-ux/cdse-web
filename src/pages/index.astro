---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ViralTechShowcase from '../components/ViralTechShowcase.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import TrustSignals from '../components/TrustSignals.astro';
---

<BaseLayout
  title="CDSE - Reparación de Electrónicos en Los Mochis"
  description="Reparación profesional de celulares, computadoras y consolas de videojuegos. Más de 16 años de experiencia y confianza."
  ogTitle="CDSE - Reparación de Celulares, Computadoras y Consolas en Los Mochis"
  ogDescription="Más de 16 años reparando celulares, computadoras y consolas de videojuegos en Los Mochis, Sinaloa. Servicio rápido y profesional. ¡Contáctanos por WhatsApp!"
  ogUrl="https://cdse.com.mx"
>
  <Hero />
  <ViralTechShowcase />
  <ServicesGrid />
  <ProductShowcase />
  <TrustSignals />
</BaseLayout>
