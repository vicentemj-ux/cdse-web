---
// Services Grid Component - Astro (zero-JS)
---

<section class="w-full py-20 px-4 bg-slate-50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Our Services</h2>
      <p class="text-xl text-slate-600">Professional repair solutions for all your electronic needs</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Cellphone Repair -->
      <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow p-8 border-t-4 border-blue-600">
        <div class="w-16 h-16 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-3">Cellphone Repair</h3>
        <p class="text-slate-600 mb-6">
          Screen repairs, battery replacements, charging port fixes, and water damage restoration for all major brands.
        </p>
        <a href="#" class="inline-block text-blue-600 font-semibold hover:text-blue-700">Learn More →</a>
      </div>

      <!-- Computer Service -->
      <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow p-8 border-t-4 border-teal-600">
        <div class="w-16 h-16 bg-teal-100 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20m0 0l-.75 3M9 20H5m4 0h8m-8 0l.75-3m0 0L15 17m0 0l.75 3m0 0l.75-3m0 0h4m-4 0h8"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-3">Computer Service</h3>
        <p class="text-slate-600 mb-6">
          Laptop repairs, desktop diagnostics, hardware upgrades, and software troubleshooting for peak performance.
        </p>
        <a href="#" class="inline-block text-teal-600 font-semibold hover:text-teal-700">Learn More →</a>
      </div>

      <!-- Console Repair -->
      <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow p-8 border-t-4 border-blue-500">
        <div class="w-16 h-16 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-3">Gaming Console Repair</h3>
        <p class="text-slate-600 mb-6">
          PS5, Xbox, Nintendo Switch repairs including controller fixes, overheating issues, and disc drive problems.
        </p>
        <a href="#" class="inline-block text-blue-500 font-semibold hover:text-blue-600">Learn More →</a>
      </div>
    </div>
  </div>
</section>
