---
// Services Grid Component - Astro (zero-JS)

interface Service {
  title: string;
  description: string;
  image: string;
}

const services: Service[] = [
  {
    title: 'Reparación de Celulares',
    description: 'Especialistas en microsoldadura de precisión, reemplazo de pantallas, baterías y restauración por daños severos.',
    image: '/services1.png',
  },
  {
    title: 'Servicio de Cómputo Avanzado',
    description: 'Diagnóstico a nivel componente de placa madre, actualización de hardware, reballing y optimización de rendimiento.',
    image: '/services2.png',
  },
  {
    title: 'Reparación de Consolas',
    description: 'Mantenimiento profundo para PS5, Xbox y Nintendo Switch. Solución definitiva de drift de joystick y sobrecalentamiento.',
    image: '/services3.png',
  },
];
---

<section class="bg-[#F5F5F7] py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16 md:mb-20">
      <h2 class="font-bold text-4xl md:text-5xl text-[#1d1d1f] tracking-tight">
        Nuestros Servicios
      </h2>
      <p class="mt-5 text-[#86868b] text-xl max-w-2xl mx-auto">
        Soluciones de ingeniería de precisión para tus dispositivos
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="group bg-white rounded-[32px] shadow-sm overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl">
          <!-- Image -->
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          <!-- Content -->
          <div class="p-8 pb-10">
            <h3 class="text-2xl font-semibold text-[#1d1d1f] mt-2">
              {service.title}
            </h3>
            <p class="text-[#86868b] leading-relaxed mt-3">
              {service.description}
            </p>
            <a
              href="#"
              class="inline-block text-[#0066cc] font-medium mt-6 hover:underline"
            >
              Más información →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
