---
// Trust Signals Component - Astro (zero-JS)
---

<section class="w-full py-20 px-4 bg-slate-50">
  <div class="max-w-6xl mx-auto">
    <!-- Brand Partners -->
    <div class="mb-20">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">Trusted Partners</h2>
        <p class="text-xl text-slate-600">Authorized service center for leading brands</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-center">
        <div class="flex items-center justify-center h-20 bg-white rounded-lg shadow-sm p-4">
          <p class="text-slate-900 font-bold text-lg">Samsung</p>
        </div>
        <div class="flex items-center justify-center h-20 bg-white rounded-lg shadow-sm p-4">
          <p class="text-slate-900 font-bold text-lg">Apple</p>
        </div>
        <div class="flex items-center justify-center h-20 bg-white rounded-lg shadow-sm p-4">
          <p class="text-slate-900 font-bold text-lg">HP</p>
        </div>
        <div class="flex items-center justify-center h-20 bg-white rounded-lg shadow-sm p-4">
          <p class="text-slate-900 font-bold text-lg">Nintendo</p>
        </div>
      </div>
    </div>

    <!-- 15 Years Badge -->
    <div class="bg-gradient-to-r from-blue-600 to-teal-600 rounded-lg p-12 text-white text-center mb-20">
      <div class="text-6xl font-bold mb-4">15 Years</div>
      <h3 class="text-3xl font-bold mb-2">of Excellence</h3>
      <p class="text-xl opacity-90">
        Serving the Los Mochis community with reliable, professional electronics repair services
      </p>
    </div>

    <!-- Testimonials -->
    <div>
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">Customer Testimonials</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-lg p-8 shadow-md border-l-4 border-blue-600">
          <div class="flex gap-1 mb-4">
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
          </div>
          <p class="text-slate-700 mb-4">
            "Excellent service! They fixed my phone screen in just 2 hours. Very professional and reasonably priced. Highly recommend!"
          </p>
          <p class="font-semibold text-slate-900">Maria González</p>
        </div>

        <div class="bg-white rounded-lg p-8 shadow-md border-l-4 border-teal-600">
          <div class="flex gap-1 mb-4">
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
          </div>
          <p class="text-slate-700 mb-4">
            "I brought my laptop with a failing drive, and they had it running like new. Great technicians and honest pricing!"
          </p>
          <p class="font-semibold text-slate-900">Carlos Rodríguez</p>
        </div>

        <div class="bg-white rounded-lg p-8 shadow-md border-l-4 border-blue-500">
          <div class="flex gap-1 mb-4">
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
            <span class="text-yellow-400">★</span>
          </div>
          <p class="text-slate-700 mb-4">
            "They&apos;ve been fixing our business computers for years. Reliable, fast, and trustworthy. Thank you CDSE!"
          </p>
          <p class="font-semibold text-slate-900">Jorge Sánchez</p>
        </div>
      </div>
    </div>
  </div>
</section>
