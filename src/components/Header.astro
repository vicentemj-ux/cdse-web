---
// Sticky header with logo, search bar, and WhatsApp contact
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-medium-gray">
  <div class="container-custom">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-electric-blue to-tech-teal rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 md:w-7 md:h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <div class="hidden sm:block">
          <span class="block text-lg md:text-xl font-bold text-text-primary">CDSE</span>
          <span class="block text-xs text-text-secondary">Centro de Soluciones Electrónicas</span>
        </div>
      </a>

      <!-- Search Bar - Desktop -->
      <div class="hidden md:flex flex-1 max-w-md mx-8">
        <div class="relative w-full">
          <input
            type="text"
            placeholder="Buscar servicios, productos..."
            class="w-full px-4 py-2.5 pl-11 bg-light-gray border border-medium-gray rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-electric-blue focus:border-transparent transition-all"
          />
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- Navigation & WhatsApp -->
      <div class="flex items-center gap-4">
        <nav class="hidden lg:flex items-center gap-6">
          <a href="#servicios" class="text-sm font-medium text-text-secondary hover:text-electric-blue transition-colors">Servicios</a>
          <a href="#productos" class="text-sm font-medium text-text-secondary hover:text-electric-blue transition-colors">Productos</a>
          <a href="#nosotros" class="text-sm font-medium text-text-secondary hover:text-electric-blue transition-colors">Nosotros</a>
        </nav>
        
        <!-- WhatsApp Quick Contact -->
        <a
          href="https://wa.me/526681234567?text=Hola,%20necesito%20información"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition-colors"
          aria-label="Contactar por WhatsApp"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="hidden sm:inline text-sm font-medium">WhatsApp</span>
        </a>

        <!-- Mobile Menu Button -->
        <button 
          class="lg:hidden p-2 rounded-lg hover:bg-light-gray transition-colors"
          aria-label="Abrir menú"
          id="mobile-menu-btn"
        >
          <svg class="w-6 h-6 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Search -->
    <div class="md:hidden pb-4 px-1">
      <div class="relative">
        <input
          type="text"
          placeholder="Buscar servicios, productos..."
          class="w-full px-4 py-2.5 pl-11 bg-light-gray border border-medium-gray rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-electric-blue focus:border-transparent"
        />
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div 
    id="mobile-menu-overlay" 
    class="fixed inset-0 bg-black/50 z-40 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
  ></div>

  <!-- Mobile Menu Panel -->
  <nav 
    id="mobile-menu-panel" 
    class="fixed top-0 right-0 h-full w-72 bg-white z-50 shadow-2xl transform translate-x-full transition-transform duration-300 ease-out lg:hidden"
  >
    <div class="flex flex-col h-full">
      <!-- Menu Header -->
      <div class="flex items-center justify-between p-4 border-b border-medium-gray">
        <span class="text-lg font-bold text-text-primary">Menu</span>
        <button 
          id="mobile-menu-close" 
          class="p-2 rounded-lg hover:bg-light-gray transition-colors"
          aria-label="Cerrar menú"
        >
          <svg class="w-6 h-6 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Menu Links -->
      <div class="flex-1 py-4">
        <a 
          href="/" 
          class="flex items-center gap-3 px-6 py-4 text-text-primary hover:bg-light-gray hover:text-electric-blue transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          <span class="font-medium">Inicio</span>
        </a>
        <a 
          href="#servicios" 
          class="flex items-center gap-3 px-6 py-4 text-text-primary hover:bg-light-gray hover:text-electric-blue transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="font-medium">Servicios</span>
        </a>
        <a 
          href="#productos" 
          class="flex items-center gap-3 px-6 py-4 text-text-primary hover:bg-light-gray hover:text-electric-blue transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
          <span class="font-medium">Catálogo</span>
        </a>
        <a 
          href="#ubicacion" 
          class="flex items-center gap-3 px-6 py-4 text-text-primary hover:bg-light-gray hover:text-electric-blue transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="font-medium">Ubicación</span>
        </a>
      </div>

      <!-- Menu Footer -->
      <div class="p-4 border-t border-medium-gray">
        <a 
          href="https://wa.me/526681234567?text=Hola,%20necesito%20información"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-green-500 text-white rounded-lg hover:bg-green-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="font-medium">Contactar por WhatsApp</span>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile Menu Toggle Functionality
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const menuOverlay = document.getElementById('mobile-menu-overlay');
  const menuPanel = document.getElementById('mobile-menu-panel');

  function openMenu() {
    menuOverlay?.classList.remove('opacity-0', 'pointer-events-none');
    menuOverlay?.classList.add('opacity-100', 'pointer-events-auto');
    menuPanel?.classList.remove('translate-x-full');
    menuPanel?.classList.add('translate-x-0');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menuOverlay?.classList.add('opacity-0', 'pointer-events-none');
    menuOverlay?.classList.remove('opacity-100', 'pointer-events-auto');
    menuPanel?.classList.add('translate-x-full');
    menuPanel?.classList.remove('translate-x-0');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  menuOverlay?.addEventListener('click', closeMenu);

  // Close menu when clicking a link
  menuPanel?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
