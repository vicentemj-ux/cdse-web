---
// Sticky header with logo, search bar, and navigation
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-medium-gray">
  <div class="container-custom">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-electric-blue to-tech-teal rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 md:w-7 md:h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <div class="hidden sm:block">
          <span class="block text-lg md:text-xl font-bold text-text-primary">CDSE</span>
          <span class="block text-xs text-text-secondary">Centro de Soluciones Electrónicas</span>
        </div>
      </a>

      <!-- Search Bar - Desktop -->
      <div class="hidden md:flex flex-1 max-w-md mx-8">
        <div class="relative w-full">
          <input
            type="text"
            placeholder="Buscar servicios, productos..."
            class="w-full px-4 py-2.5 pl-11 bg-light-gray border border-medium-gray rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-electric-blue focus:border-transparent transition-all"
          />
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- Navigation -->
      <div class="flex items-center gap-4">
        <nav class="hidden lg:flex items-center gap-6">
          <a href="#servicios" class="text-sm font-medium text-text-secondary hover:text-electric-blue transition-colors">Servicios</a>
          <a href="/ubicacion" class="text-sm font-medium text-text-secondary hover:text-electric-blue transition-colors">Ubicación</a>
          <a href="#nosotros" class="text-sm font-medium text-text-secondary hover:text-electric-blue transition-colors">Nosotros</a>
        </nav>

        <!-- Mobile Menu Button -->
        <button 
          class="lg:hidden p-2 rounded-lg hover:bg-light-gray transition-colors"
          aria-label="Abrir menú"
          id="mobile-menu-btn"
        >
          <svg class="w-6 h-6 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Search -->
    <div class="md:hidden pb-4 px-1">
      <div class="relative">
        <input
          type="text"
          placeholder="Buscar servicios, productos..."
          class="w-full px-4 py-2.5 pl-11 bg-light-gray border border-medium-gray rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-electric-blue focus:border-transparent"
        />
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>
  </div>
</header>
