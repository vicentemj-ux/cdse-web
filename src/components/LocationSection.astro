---
// Visit Our Hub - Location Section with map and store info
---

<section id="ubicacion" class="py-16 md:py-24 bg-light-gray">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <span class="inline-block px-4 py-1.5 bg-electric-blue/10 text-electric-blue text-sm font-semibold rounded-full mb-4">
        Visítanos
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4 text-balance">
        Visit Our Tech Hub
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto text-pretty">
        Encuentra nuestro centro de servicio en el corazón de Los Mochis, Sinaloa. 
        Estamos listos para atenderte.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 items-stretch">
      <!-- Map Placeholder -->
      <div class="relative rounded-2xl overflow-hidden bg-white shadow-lg border border-medium-gray min-h-[400px]">
        <!-- Map Mockup -->
        <div class="absolute inset-0 bg-gradient-to-br from-slate-100 to-slate-200">
          <!-- Grid Pattern for Map Effect -->
          <div class="absolute inset-0 opacity-30" style="background-image: linear-gradient(rgba(0,123,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,123,255,0.1) 1px, transparent 1px); background-size: 40px 40px;"></div>
          
          <!-- Roads -->
          <div class="absolute top-1/2 left-0 right-0 h-3 bg-slate-300 transform -translate-y-1/2"></div>
          <div class="absolute left-1/2 top-0 bottom-0 w-3 bg-slate-300 transform -translate-x-1/2"></div>
          <div class="absolute top-1/4 left-0 right-0 h-2 bg-slate-200"></div>
          <div class="absolute left-1/4 top-0 bottom-0 w-2 bg-slate-200"></div>
          <div class="absolute left-3/4 top-0 bottom-0 w-2 bg-slate-200"></div>
          
          <!-- Location Pin -->
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-full">
            <div class="relative animate-bounce">
              <div class="w-12 h-12 bg-electric-blue rounded-full flex items-center justify-center shadow-lg shadow-electric-blue/40">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
              </div>
              <div class="absolute -bottom-1 left-1/2 transform -translate-x-1/2 w-3 h-3 bg-electric-blue rotate-45"></div>
            </div>
          </div>

          <!-- Zoom Controls Mock -->
          <div class="absolute top-4 right-4 flex flex-col gap-1">
            <div class="w-8 h-8 bg-white rounded shadow flex items-center justify-center text-slate-500">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </div>
            <div class="w-8 h-8 bg-white rounded shadow flex items-center justify-center text-slate-500">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
              </svg>
            </div>
          </div>

          <!-- Map Label -->
          <div class="absolute bottom-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-2 rounded-lg shadow-sm">
            <span class="text-xs font-medium text-text-secondary">Los Mochis, Sinaloa</span>
          </div>
        </div>

        <!-- Overlay for interaction -->
        <a 
          href="https://maps.google.com/?q=CDSE+Los+Mochis+Sinaloa"
          target="_blank"
          rel="noopener noreferrer"
          class="absolute inset-0 flex items-center justify-center bg-black/0 hover:bg-black/10 transition-colors group"
        >
          <div class="opacity-0 group-hover:opacity-100 transition-opacity bg-white px-4 py-2 rounded-lg shadow-lg flex items-center gap-2">
            <svg class="w-5 h-5 text-electric-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            <span class="text-sm font-medium text-text-primary">Abrir en Google Maps</span>
          </div>
        </a>
      </div>

      <!-- Store Information -->
      <div class="bg-white rounded-2xl shadow-lg border border-medium-gray p-8 flex flex-col">
        <!-- Address -->
        <div class="flex gap-4 mb-8">
          <div class="flex-shrink-0 w-12 h-12 bg-electric-blue/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-electric-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary mb-1">Dirección</h3>
            <p class="text-text-secondary">
              Blvd. Antonio Rosales #456<br>
              Col. Centro, Los Mochis<br>
              Sinaloa, México CP 81200
            </p>
          </div>
        </div>

        <!-- Store Hours -->
        <div class="flex gap-4 mb-8">
          <div class="flex-shrink-0 w-12 h-12 bg-tech-teal/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-tech-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary mb-1">Horario de Atención</h3>
            <div class="text-text-secondary space-y-1">
              <div class="flex justify-between gap-8">
                <span>Lunes - Viernes</span>
                <span class="font-medium text-text-primary">9:00 AM - 7:00 PM</span>
              </div>
              <div class="flex justify-between gap-8">
                <span>Sábado</span>
                <span class="font-medium text-text-primary">10:00 AM - 3:00 PM</span>
              </div>
              <div class="flex justify-between gap-8">
                <span>Domingo</span>
                <span class="font-medium text-red-500">Cerrado</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex gap-4 mb-8">
          <div class="flex-shrink-0 w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary mb-1">Teléfono</h3>
            <a href="tel:+526681234567" class="text-electric-blue hover:underline">
              (668) 123-4567
            </a>
          </div>
        </div>

        <!-- Get Directions Button -->
        <div class="mt-auto pt-4">
          <a 
            href="https://maps.google.com/maps/dir//CDSE+Los+Mochis+Sinaloa"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full px-6 py-4 bg-electric-blue text-white font-semibold rounded-xl hover:bg-electric-blue/90 transition-colors shadow-lg shadow-electric-blue/25"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            Get Directions
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
